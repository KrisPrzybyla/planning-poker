{
  "name": "Planning Poker",
  "description": "Simple Planning Poker application with Fibonacci cards for Agile teams",
  "repository": "https://github.com/yourusername/planning-poker",
  "logo": "https://cdn.jsdelivr.net/npm/twemoji@11.3.0/2/svg/1f0cf.svg",
  "keywords": ["planning-poker", "agile", "scrum", "fibonacci", "estimation", "nodejs", "react"],
  "image": "heroku/nodejs",
  "stack": "heroku-22",
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ],
  "env": {
    "NODE_ENV": {
      "description": "Node environment",
      "value": "production"
    },
    "NPM_CONFIG_PRODUCTION": {
      "description": "Skip dev dependencies",
      "value": "false"
    }
  },
  "formation": {
    "web": {
      "quantity": 1,
      "size": "basic"
    }
  },
  "addons": [],
  "scripts": {
    "postdeploy": "echo 'Planning Poker deployed successfully!'"
  }
}